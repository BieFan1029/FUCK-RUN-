<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 淡蓝主题 -->
    <style name="Theme.RunHook" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorPrimaryDark">@color/primary_blue_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:colorBackground">@color/background_blue</item>
        <item name="colorSurface">@color/card_white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/primary_blue</item>
        <item name="android:navigationBarColor">@color/primary_blue_dark</item>
    </style>

    <!-- 卡片样式 -->
    <style name="CardStyle">
        <item name="android:background">@drawable/card_background</item>
        <item name="android:elevation">4dp</item>
    </style>

    <!-- 主按钮样式 -->
    <style name="PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/button_primary</item>
        <item name="android:textColor">@color/card_white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">24dp</item>
    </style>

    <!-- 次要按钮样式 -->
    <style name="SecondaryButton" parent="Widget.Material3.Button.TonalButton">
        <item name="android:backgroundTint">@color/primary_blue_light</item>
        <item name="android:textColor">@color/card_white</item>
    </style>
</resources>
